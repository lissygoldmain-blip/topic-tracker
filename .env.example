# ── LLM ──────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
# Max Gemini calls per poller run (across all topics). Default 20 is conservative
# — raise once you have real usage data. In GitHub Actions, set as a repository
# variable (Settings → Variables → Actions) rather than a secret.
STAGE1_MAX_ITEMS_PER_RUN=20

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=
TO_EMAIL=your@email.com
FROM_EMAIL=tracker@updates.resend.dev

# ── Shopping APIs ─────────────────────────────────────────────────────────────
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
ETSY_API_KEY=

# ── News / Video (optional — adapters skip gracefully if not set) ─────────────
NEWSAPI_KEY=
NYTIMES_API_KEY=
GUARDIAN_API_KEY=
YOUTUBE_API_KEY=

# ── Jobs (optional — Adzuna aggregates LinkedIn + Indeed + 1000s of boards) ──
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ── Science (optional — raises NCBI rate limit from 3 to 10 req/sec) ─────────
NCBI_API_KEY=

# ── Entertainment (optional — upcoming movies & TV via TMDb) ──────────────────
TMDB_API_KEY=

# ── No credentials needed ─────────────────────────────────────────────────────
# google_news, hacker_news, reddit, rss, bluesky, mastodon, grailed
# pubmed, arxiv, weather, gdelt, camelcamelcamel, slickdeals
